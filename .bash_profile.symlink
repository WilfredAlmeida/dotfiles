#!/usr/bin/env bash

mkdir -p "$HOME/bin" "$HOME/.local/bin"

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) PATH="$HOME/.local/bin:$PATH" ;;
esac

case ":$PATH:" in
  *":$HOME/bin:"*) ;;
  *) PATH="$HOME/bin:$PATH" ;;
esac

export PATH

if [ -f "$HOME/.bashrc" ]; then
  # Login shells should load interactive configuration, not the reverse.
  # shellcheck source=/dev/null
  source "$HOME/.bashrc"
fi
